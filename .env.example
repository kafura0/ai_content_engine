# ── FastAPI ────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
IMAGE_RETRY_COUNT=3

# Supabase session pooler (port 5432, not the transaction pooler on 6543)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Supabase JWT secret — Settings → API → JWT Secret in the Supabase dashboard
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# CORS — comma-separated origins allowed (frontend URLs).
# Defaults: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── n8n (only needed if using async generation path) ──────────────────────────
# N8N_WEBHOOK_URL=https://YOUR_N8N.fly.dev/webhook/generate-content

# ── Next.js (local dev) ────────────────────────────────────────────────────────
# Supabase — get from Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
