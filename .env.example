# ── FastAPI ────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_TEXT_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
IMAGE_RETRY_COUNT=3

# Supabase session pooler (port 5432, not the transaction pooler on 6543)
DATABASE_URL=postgresql+asyncpg://postgres.csjheyqwmsdvsufbmurj:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Supabase JWT secret — Settings → API → JWT Secret in the Supabase dashboard
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Optional: comma-separated extra origins for CORS (Vercel preview URLs, etc.)
# EXTRA_ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Next.js ────────────────────────────────────────────────────────────────────
# Supabase — get from Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Local docker-compose testing:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (set as Dokploy build arg):
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
